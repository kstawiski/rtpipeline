Bootstrap: docker
From: kstawiski/rtpipeline:2.2.3

%labels
    Author kstawiski
    Version 2.2.3
    Description DICOM-RT pipeline with TotalSegmentator, nnUNet, and Snakemake
    org.label-schema.name rtpipeline
    org.label-schema.description Radiotherapy DICOM processing pipeline
    org.label-schema.url https://github.com/kstawiski/rtpipeline
    org.label-schema.vcs-url https://github.com/kstawiski/rtpipeline
    org.label-schema.schema-version 1.0

%help
    RTpipeline 2.2.3 - Radiotherapy DICOM Processing Pipeline

    This definition deliberately converts the version-matched canonical Docker
    image instead of rebuilding a second dependency stack. Build it after the
    2.2.3 image is published:

      apptainer build rtpipeline-2.2.3.sif rtpipeline.def

    Run the pipeline with explicit data bindings:

      apptainer exec --nv \
        --bind /path/to/input:/data/input:ro \
        --bind /path/to/output:/data/output:rw \
        --bind /path/to/logs:/data/logs:rw \
        rtpipeline-2.2.3.sif \
        snakemake --cores all --configfile /app/config.container.yaml

    For more information, visit https://github.com/kstawiski/rtpipeline.

%runscript
    cd /app
    exec python webui/app.py "$@"
